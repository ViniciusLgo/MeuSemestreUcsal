# Copie este arquivo para .env.local e preencha os valores
# cp .env.example .env.local

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Desenvolvimento local: rode `supabase start` e use as credenciais geradas pelo CLI
# Produção: encontre no painel Supabase em Settings > API
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ─────────────────────────────────────────────────────────────────────
# Em produção: https://seudominio.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Telegram (opcional) ─────────────────────────────────────────────────────
# 1. Crie um bot com @BotFather e copie o token aqui
# 2. Envie /start para o bot e acesse /api/telegram/setup para obter seu chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
