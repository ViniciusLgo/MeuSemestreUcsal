# Supabase — crie um projeto em https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_<sua-anon-key>
SUPABASE_SERVICE_ROLE_KEY=sb_secret_<sua-service-role-key>

# URL base do projeto (usado em links nas notificações Telegram)
# Em produção: https://seudominio.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Telegram Bot (opcional — notificações de admin)
# 1. Crie um bot com @BotFather e copie o token aqui
# 2. Envie /start para o bot e acesse /api/telegram/setup para obter seu chat_id
TELEGRAM_BOT_TOKEN=<token_do_botfather>
TELEGRAM_ADMIN_CHAT_ID=<seu_chat_id>
