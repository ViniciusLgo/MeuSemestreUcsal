# Copie este arquivo para .env.local e preencha os valores
# cp .env.example .env.local

# ─── Supabase ─────────────────────────────────────────────────────────────────
# ── Ambiente LOCAL (padrão após `supabase start`) ─────────────────────────────
# Estas chaves são públicas e idênticas em todo projeto Supabase CLI local.
# Só funcionam contra localhost — não são segredos.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7w9Ic0HSntANWdMrCbCQFlq_u_AoQAFbNEU
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SBc0

# ── Ambiente de PRODUÇÃO ───────────────────────────────────────────────────────
# Substitua pelos valores reais em Settings > API no painel do Supabase.
# NEXT_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ─── App ─────────────────────────────────────────────────────────────────────
# Em produção: https://seudominio.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Telegram (opcional) ─────────────────────────────────────────────────────
# 1. Crie um bot com @BotFather e copie o token aqui
# 2. Envie /start para o bot e acesse /api/telegram/setup para obter seu chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
